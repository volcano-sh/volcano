        { "expr": "histogram_quantile(0.99, sum by (action, le) (rate(volcano_action_scheduling_latency_milliseconds_bucket[1m])))", "legendFormat": "{{action}} P99", "refId": "B" }
      ],
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } }
