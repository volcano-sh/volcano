{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Volcano Batch Scheduler",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "Session Duration (ms)",
      "description": "One full scheduling session, from opening the session through running actions.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum by (le) (rate(volcano_e2e_scheduling_latency_milliseconds_bucket[1m])))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(volcano_e2e_scheduling_latency_milliseconds_bucket[1m])))", "legendFormat": "P99", "refId": "B" }
      ],
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 3,
      "title": "Open Session Duration (ms)",
      "description": "Time spent preparing a scheduling session before actions run.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum by (le) (rate(volcano_open_session_duration_milliseconds_bucket[1m])))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(volcano_open_session_duration_milliseconds_bucket[1m])))", "legendFormat": "P99", "refId": "B" }
      ],
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 4,
      "title": "Job Scheduling Duration (ms)",
      "description": "Per-job time from VCJob creation until the last task is assumed in scheduler cache.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 5, "drawStyle": "line", "showPoints": "always", "pointSize": 6 } }
      },
      "targets": [
        { "expr": "volcano_e2e_job_scheduling_duration{job_namespace=\"default\"}", "legendFormat": "{{job_name}}", "refId": "A" }
      ],
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 5,
      "title": "Task Stage Latency P50 (ms)",
      "description": "Median pod time from creation to each scheduler stage: watched, assumed, pre-bound, and bound.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum by (le) (rate(volcano_task_scheduling_latency_milliseconds_bucket{stage=\"Watched\"}[1m])))", "legendFormat": "Watched", "refId": "A" },
        { "expr": "histogram_quantile(0.5, sum by (le) (rate(volcano_task_scheduling_latency_milliseconds_bucket{stage=\"Assumed\"}[1m])))", "legendFormat": "Assumed", "refId": "B" },
        { "expr": "histogram_quantile(0.5, sum by (le) (rate(volcano_task_scheduling_latency_milliseconds_bucket{stage=\"PreBound\"}[1m])))", "legendFormat": "PreBound", "refId": "C" },
        { "expr": "histogram_quantile(0.5, sum by (le) (rate(volcano_task_scheduling_latency_milliseconds_bucket{stage=\"Bound\"}[1m])))", "legendFormat": "Bound", "refId": "D" }
      ],
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 6,
      "title": "Task Stage Latency P99 (ms)",
      "description": "Tail pod time from creation to each scheduler stage.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(volcano_task_scheduling_latency_milliseconds_bucket{stage=\"Watched\"}[1m])))", "legendFormat": "Watched", "refId": "A" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(volcano_task_scheduling_latency_milliseconds_bucket{stage=\"Assumed\"}[1m])))", "legendFormat": "Assumed", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(volcano_task_scheduling_latency_milliseconds_bucket{stage=\"PreBound\"}[1m])))", "legendFormat": "PreBound", "refId": "C" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(volcano_task_scheduling_latency_milliseconds_bucket{stage=\"Bound\"}[1m])))", "legendFormat": "Bound", "refId": "D" }
      ],
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 7,
      "title": "Stage Processing Time (ms)",
      "description": "Time spent inside each scheduler stage: predicate, scoring, pre-bind, and bind.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum by (stage, le) (rate(volcano_scheduling_stage_duration_milliseconds_bucket[1m])))", "legendFormat": "{{stage}} P50", "refId": "A" },
        { "expr": "histogram_quantile(0.99, sum by (stage, le) (rate(volcano_scheduling_stage_duration_milliseconds_bucket[1m])))", "legendFormat": "{{stage}} P99", "refId": "B" }
      ],
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } }
    },
    {
      "id": 8,
      "title": "Action Duration (ms)",
